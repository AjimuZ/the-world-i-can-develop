{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/confirm-git-commit-push.cjs",
            "if": "Bash(git *)"
          },
          {
            "type": "command",
            "command": ".claude/hooks/block-dangerous.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/secret-scan.sh"
          }
        ]
      },
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/confirm-git-commit-push.cjs",
            "if": "PowerShell(git *)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-format-after-edit.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/test-reminder-after-source-change.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/docs-required-reminder.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/roadmap-reminder-after-change.sh"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/changelog-reminder-after-change.cjs"
          },
          {
            "type": "command",
            "command": ".claude/hooks/public-tone-guard.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/phase-summary.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "ask": [
      "Bash(git commit *)",
      "Bash(git push *)",
      "PowerShell(git commit *)",
      "PowerShell(git push *)"
    ]
  }
}
