# EditorConfig — https://editorconfig.org
# Shared formatting baseline for a multi-language repo (Java, TypeScript, HTML, SCSS).
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Java conventionally uses 4-space indentation.
[*.java]
indent_size = 4

# Preserve hard line breaks (two trailing spaces) in Markdown.
[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab
