# Copy this file to .env and adjust the values for your local environment.
# .env is gitignored; this .env.example is committed with placeholders only.
# Do not put real secrets in this file.

# --- PostgreSQL (Docker Compose, from P7) ---
POSTGRES_DB=demon_king
POSTGRES_USER=demon_king
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# --- Spring Boot datasource (backend, from P7/P8) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/demon_king
SPRING_DATASOURCE_USERNAME=demon_king
SPRING_DATASOURCE_PASSWORD=change_me

# --- Backend server ---
SERVER_PORT=8080

# --- Local LLM via Ollama (used from P17 onward) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=

# --- Frontend dev server ---
FRONTEND_PORT=4200
