# Normalize line endings: store as LF in the repo and check out LF on every
# platform. Keeps the .editorconfig (end_of_line = lf) authoritative and keeps
# the .claude/hooks/*.sh scripts runnable under Git Bash on Windows.
* text=auto eol=lf

# Binary assets must never be normalized.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.pdf  binary
*.jar  binary
