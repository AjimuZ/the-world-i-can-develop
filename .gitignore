# ===== The World I Can Develop — root ignore rules =====
# Monorepo: frontend/ (Angular + TypeScript), backend/ (Spring Boot + Maven).

# --- OS ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Editors / IDEs ---
.idea/
*.iml
*.ipr
*.iws
.vscode/*
!.vscode/extensions.json
*.swp
*.swo
*~

# --- Environment / secrets ---
.env
.env.*
!.env.example

# --- Logs ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Node / Angular (frontend/) ---
node_modules/
dist/
out-tsc/
.angular/
coverage/
*.tsbuildinfo
.eslintcache

# --- Java / Maven (backend/) ---
# Build output only. The Maven wrapper jar lives under .mvn/wrapper/ and is kept.
target/
build/
*.class
hs_err_pid*
replay_pid*

# --- Misc ---
tmp/
*.pid
